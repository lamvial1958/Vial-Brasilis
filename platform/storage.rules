rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Áudio de TTS pré-gerado (diálogos/listening) — leitura pública, escrita só via Admin SDK.
    match /audio/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Gravações de produção oral dos alunos — só o próprio aluno e o admin.
    match /producao-oral/{uid}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == uid || request.auth.token.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
